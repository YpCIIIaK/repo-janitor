{
  "name": "@repo-anti-rot/cli",
  "version": "0.0.0",
  "description": "Command-line interface for Repo Anti-Rot scanning engine",
  "type": "module",
  "bin": {
    "repo-anti-rot": "./dist/index.js"
  },
